{
  "timeout_seconds": 120,
  "max_parallel": 4,
  "verify_wait_seconds": 30,
  "verify_interval_seconds": 2,
  "bootstrap_cmd": "set -e; mkdir -p /opt/cloak-manager-worker/config; DOCKER=\"docker\"; docker ps >/dev/null 2>&1 || DOCKER=\"sudo -n docker\"; $DOCKER --version >/dev/null 2>&1; $DOCKER pull ghcr.io/gscr10/cloakbrowser-orchestration-manager-worker:latest",
  "start_cmd": "set -e; DOCKER=\"docker\"; docker ps >/dev/null 2>&1 || DOCKER=\"sudo -n docker\"; $DOCKER --version >/dev/null 2>&1; $DOCKER rm -f cloak-manager-worker >/dev/null 2>&1 || true; $DOCKER run -d --name cloak-manager-worker --restart unless-stopped --shm-size=512m -p 8080:8080 -v cloak-manager-data:/data -v /opt/cloak-manager-worker/config:/config:ro -e CONFIG_IMPORT_ON_START=true -e CONFIG_DIR=/config -e DISTRIBUTED_WORKER_ENABLED=true -e WORKER_NODE_ID={node_id} -e MASTER_BASE_URL={master_base_url} -e WORKER_API_BASE={worker_api_base} -e AUTH_TOKEN={auth_token} ghcr.io/gscr10/cloakbrowser-orchestration-manager-worker:latest"
}
